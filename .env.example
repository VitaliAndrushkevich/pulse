# =============================================================================
# Pulse — Environment Configuration
# =============================================================================
# Copy this file to .env and replace placeholder values before running:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# ---------- Application ----------

# HTTP port the Pulse server listens on (inside container)
PULSE_PORT=8080

# Enable dev mode (serves Swagger UI, enables debug logging)
# Set to "false" in production
PULSE_DEV=false

# Number of concurrent monitor check workers
# Recommended: 50 for development, 200 for production (500+ monitors)
PULSE_SCHEDULER_WORKERS=200

# ---------- Security ----------

# AES-256-GCM encryption key for secrets at rest (32 bytes, base64-encoded)
# Generate with: openssl rand -base64 32
# REQUIRED — application will not start without this
PULSE_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# Secret used to sign JWT authentication tokens
# Use a long random string. Generate with: openssl rand -hex 32
# REQUIRED — must be changed in production
PULSE_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT token expiry duration (Go duration format)
# Examples: 24h, 12h, 1h30m
PULSE_JWT_EXPIRY=24h

# ---------- Database ----------

# PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=disable
# The default below connects to the compose postgres service
DATABASE_URL=postgres://pulse:pulse@postgres:5432/pulse?sslmode=disable
