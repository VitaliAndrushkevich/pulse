# =============================================================================
# Pulse — Environment Configuration
# =============================================================================
# Copy this file to .env and replace placeholder values before running:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# ---------- Application ----------

# HTTP port the Pulse server listens on (inside container)
PULSE_PORT=8080

# Enable dev mode (serves Swagger UI, enables debug logging)
# Set to "false" in production
PULSE_DEV=false

# Public base URL used for generating links in email notifications
# (e.g. "View Monitor" button). Leave empty to omit links from emails.
# Examples: https://pulse.example.com, http://localhost:8080
# PULSE_BASE_URL=https://pulse.example.com

# Number of concurrent monitor check workers
# Recommended: 50 for development, 200 for production (500+ monitors)
PULSE_SCHEDULER_WORKERS=200

# ---------- Notification Dispatcher ----------

# Number of concurrent notification delivery workers (goroutine pool)
# Separate from scheduler workers to isolate notification failures from monitoring.
# Recommended: 10 for development, 50 for production
PULSE_NOTIFICATION_WORKERS=50

# Maximum time to wait for in-flight notifications to complete during shutdown
# (Go duration format). After this timeout, remaining deliveries are cancelled.
# Examples: 30s, 1m, 45s
PULSE_NOTIFICATION_DRAIN_TIMEOUT=30s

# Log verbosity for notification delivery.
# "warn" (default) — errors and warnings only.
# "info" or "debug" — includes delivery events with payload details.
PULSE_LOG_LEVEL=warn

# ---------- Metrics ----------

# Optional Basic Auth credentials for the /metrics endpoint.
# When both are set, Prometheus scraping requires these credentials.
# Leave empty to expose /metrics without authentication.
# PULSE_METRICS_USER=prometheus
# PULSE_METRICS_PASSWORD=CHANGE_ME_generate_a_strong_password

# ---------- Security ----------

# AES-256-GCM encryption key for secrets at rest (32 bytes, base64-encoded)
# Generate with: openssl rand -base64 32
# REQUIRED — application will not start without this
PULSE_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# Secret used to sign JWT authentication tokens
# Use a long random string. Generate with: openssl rand -hex 32
# REQUIRED — must be changed in production
PULSE_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT token expiry duration (Go duration format)
# Examples: 24h, 12h, 1h30m
PULSE_JWT_EXPIRY=24h

# ---------- Metrics ----------

# HTTP Basic Auth credentials for the /metrics (Prometheus) endpoint.
# When both are set, scraping requires Basic Auth. When either is empty,
# the endpoint remains open (useful for development / trusted networks).
# Prometheus scrape_config example:
#   basic_auth:
#     username: "prometheus"
#     password: "changeme"
# PULSE_METRICS_USER=prometheus
# PULSE_METRICS_PASSWORD=changeme

# ---------- Database ----------

# PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=disable
# The default below connects to the compose postgres service
DATABASE_URL=postgres://pulse:pulse@postgres:5432/pulse?sslmode=disable

# ---------- MCP Server ----------

# Pulse API token used by the MCP server to authenticate to the Pulse API.
# Generate one in Pulse Settings → API Tokens.
# REQUIRED — the MCP server will not start without this.
PULSE_MCP_API_TOKEN=

# Base URL of the Pulse REST API (default: http://localhost:8080/api/v1)
# PULSE_MCP_API_BASE_URL=http://localhost:8080/api/v1

# Access mode: "read-only" (default) or "read-write"
# In read-only mode, only read tools are available.
# In read-write mode, the create-monitor tool is also exposed.
# PULSE_MCP_ACCESS_MODE=read-only

# Transport: "stdio" (default, local single-client) or "http" (Streamable HTTP, networked)
# PULSE_MCP_TRANSPORT=stdio

# Per-request timeout for Pulse API calls (Go duration format, default: 15s)
# PULSE_MCP_REQUEST_TIMEOUT=15s
